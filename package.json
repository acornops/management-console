{
  "name": "acornops-management-console",
  "private": true,
  "version": "0.0.1-experimental.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "smoke:nginx": "node scripts/smoke-nginx-headers.mjs",
    "membership:check": "node scripts/check-workspace-membership.mjs",
    "contracts:check": "node scripts/check-contracts.mjs",
    "harness:check": "node scripts/check-harness.mjs",
    "validate": "npm run lint && npm run test && npm run membership:check && npm run contracts:check && npm run harness:check && npm run build && npm run smoke:routes",
    "validate:ci": "npm run lint && npm run test:coverage && npm run membership:check && npm run contracts:check && npm run harness:check && npm run build && npm run smoke:routes"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "i18next": "^26.0.10",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.7",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.5"
  }
}
