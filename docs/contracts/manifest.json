      "workflowCapabilityCeiling": {
        "rule": "A workflow selects one or more active reviewed specialist Agents. restrictionMode=inherit resolves their current combined ceiling at session creation; restrictionMode=restrict requires semanticCapabilityIds to be an explicit subset.",
        "emptyRestrictionSemantics": "inherit requires an empty semanticCapabilityIds array. restrict may use an empty array to intentionally authorize no semantic capabilities. Stored legacy workflows migrate to restrict, legacy requests that omit restrictionMode preserve restrict semantics, and the console always sends restrictionMode explicitly.",
        "agentOnlyAdditions": ["mcp_servers", "mcp_tools", "skills"],
        "runtimeToolIdentity": "McpToolRef{serverId,toolName}; legacy strings are accepted only when unambiguous"
      },
      "workflowRuntimePolicy": {
        "authority": "AGENT_MAX_RUNTIME_MS is the only workflow execution limit and TARGET_CHAT_REPORT_RETENTION_DAYS is the only workflow and target-chat report retention policy.",
        "mutationCompatibility": "Legacy maxRuntimeSeconds and retentionDays fields are accepted but ignored and cannot override deployment policy.",
        "response": "Workflow responses normalize maxRuntimeSeconds and retentionDays to effective deployment values.",
        "options": "Workflow option catalogs expose one effective runtime limit and one effective retention policy.",
        "manualDefaults": "When omitted, the server defaults manual workflows to read_only, inherit, workspace_metadata, read_workspace_data, and no approval requirements."
      },
      "workflowCapabilityPreview": {
        "path": "POST /api/v1/workflows/{workflowId}/capabilities-preview",
        "authorization": "Requires workspace-data read and the workflow mode's run-creation capability.",
        "snapshot": "Target candidates, mappings, and Agent registrations are evaluated from one request snapshot. The selected target is reloaded and its stored target type is authoritative.",
        "statuses": ["needs_target", "ready", "blocked"],
        "targetStatuses": ["ready", "unavailable", "unsupported"],
        "mcpAuthRequirements": "Every credentialed MCP server in the compiled Agent scope emits mcpRequirements[].{serverId,serverName,authType,owningAgent.{id,name},connectionState,authRequirement.{scope,credentialLabel,requiredInformation[].{name,description}},action}; generic connection metadata and guidance only, never provider profiles, URLs, headers, or credential values",
        "privacy": "Responses expose bounded reason codes and public compiled scope only; credentials, URLs, headers, tool arguments, input schemas, private connection state, and internal coordinator identity are excluded.",
        "mutation": "Preview creates no session, execution, run, approval, or audit record. Dispatch recompiles and returns the authoritative compiledAccessScope."
      },
      "workspaceNativeToolContract": {
        "catalog": ["chat.sessions.read_selected", "reports.pdf.generate"],
        "ownership": "Control-plane code owns workspace-native metadata, schemas, authorization class, audit operation, and execution.",
        "assignment": "manage_agents grants or revokes a tool on a specialist Agent and transactionally rebinds exact reviewed mappings and dependent readiness; manage_mcp is not required.",
        "modelAliases": { "chat.sessions.read_selected": "acornops_read_selected_chat_sessions", "reports.pdf.generate": "acornops_generate_pdf_report" },
        "invocationScopePolicy": "Workspace-native declarations carry invocationScopes. chat.sessions.read_selected supports workflow; reports.pdf.generate supports workflow and target_chat; direct Agent invocation returns WORKSPACE_NATIVE_TOOL_SCOPE_DENIED.",
        "artifactSafety": "reports.pdf.generate is a control-plane-owned internal_artifact available to workflows and target chat without crossing the target-adapter boundary. It is allowed in read-only runs without write approval, persisted as a write audit event, bounded, provenance-linked, authenticated, and idempotent by workflow run or target run plus tool_call_id.",
        "selectedChats": "chat.sessions.read_selected requires selected_chat_sessions approval and may read only same-workspace session IDs pinned in the workflow execution input.",
        "ui": "Agent Capabilities > Tools lists AcornOps native tools separately from MCP-discovered tools. Grant and revoke require manage_agents only.",
        "workflowUi": "Create defaults to inheritance after Agent selection. Advanced restriction supports narrowed and intentionally empty sets; review and readiness copy distinguish policy from effective capabilities.",
        "artifactUi": "Workflow and target-chat assistant responses expose authenticated PDF download cards returned by reports.pdf.generate; Copy remains a separate response action."
      },
      "workflowRoutingContract": {
        "request": "required unique non-empty agentIds; entryAgentId, delegationPolicy, and executionMode are rejected with WORKFLOW_ROUTING_FIELDS_REMOVED",
        "response": "executionMode is derived as direct for one selected Agent or coordinated for two or more; selection order has no meaning",
        "coordinationTrace": "GET workflow execution returns only bounded child capability, target, specialist, status, and failure; internal coordinator identity and sensitive execution content are omitted",
        "cancellation": "parent cancellation cascades to active coordinated child runs"
      },
      "systemAutomationDefinitions": {
        "provisioning": "Workflow schema epoch 2 is a first-install or explicit-reset cutover. Workspace creation atomically commits four visible specialist Agents, five workflows, persistent system-owned coordination infrastructure, and a completed starter-v2 installation after the reset-safe migration succeeds; incompatible V1 records abort migration with WORKFLOW_V2_DATABASE_RESET_REQUIRED.",
        "attribution": "Template-origin Agents and workflows are labeled as system provided and retain their template ID and version.",
        "visibility": "Public Agent APIs contain specialists only. Manager creation or configuration returns MANAGER_SYSTEM_OWNED, direct access returns 404, and public workflow, compiled-scope, audit, search, and trace DTOs omit internal coordinator identity.",
        "mutation": "Visible template-origin definitions accept availability-status changes, supported external bindings, duplication, and deletion. Definition edits and version restore remain immutable; Agent deletion returns structured dependent workflows until those dependencies are removed.",
        "duplication": "manage_agents or manage_workflows may copy the effective definition into a manual draft without capability installations, history, runs, schedules, sessions, activity, or triggers."
      },
      "catalogAuthorization": {
        "manageSources": "manage_catalog_sources",
        "installAgentMcp": ["manage_agents", "manage_mcp"],
        "installAgentSkills": ["manage_agents", "manage_skills"],
        "installTargetMcp": "manage_mcp",
        "toolReview": "scope-specific tool permission",
