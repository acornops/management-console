        "workspace.created.v1",
        "workspace.deleted.v1",
        "target.registered.v1",
        "target.updated.v1",
        "target.deleted.v1",
        "target.status_changed.v1",
        "agent.connected.v1",
        "agent.disconnected.v1",
        "agent.capabilities_changed.v1",
        "agent.key_rotated.v1",
        "session.created.v1",
        "session.deleted.v1",
        "message.received.v1",
        "run.created.v1",
        "run.started.v1",
        "run.completed.v1",
        "run.failed.v1",
        "run.cancelled.v1",
        "run.cancel_requested.v1",
        "run.tool_approval_requested.v1",
        "run.tool_approval_decided.v1",
        "tool.called.v1",
        "mcp.server.created.v1",
        "mcp.server.updated.v1",
        "mcp.server.deleted.v1",
        "mcp.server.tested.v1",
        "tool.catalog.changed.v1"
      ],
      "eventTypes": [
        "run_progress",
        "run_started",
        "assistant_message_started",
        "assistant_token_delta",
        "assistant_reasoning_summary_delta",
        "assistant_reasoning_summary_completed",
        "assistant_reasoning_summary_unavailable",
        "tool_call_started",
        "tool_call_completed",
        "tool_approval_requested",
        "tool_approval_approved",
        "tool_approval_rejected",
        "tool_approval_expired",
        "assistant_message_completed",
        "run_failed",
        "run_cancelled",
        "run_completed"
      ],
      "targetChatActivityEventTypes": [
        "message.created",
        "run.created",
        "run.status_changed",
        "assistant_message.committed",
        "approval.requested",
        "approval.decided",
        "approval.expired",
        "session.deleted"
      ],
      "snapshotFields": [
        "latestSnapshot.{clusterId,workspaceId,timestamp}",
        "summary.{resourceCount,findingCount,criticalFindingCount,namespaceCount,nodeCount,resourceFamilyCounts,resourceKindCounts}",
        "virtualMachine.latestSnapshot.{targetId,workspaceId,timestamp}",
        "virtualMachine.summary.{inventoryCount,findingCount,criticalFindingCount,serviceCount,processCount,listenerCount,logCount}",
        "GET /api/v1/workspaces/{workspaceId}/investigations",
        "GET /api/v1/workspaces/{workspaceId}/kubernetes-clusters/{clusterId}/resources",
        "GET /api/v1/workspaces/{workspaceId}/kubernetes-clusters/{clusterId}/findings"
      ],
      "catalogFields": [
        "permissions.canEdit",
        "permissions.editableRoles",
        "mcpCatalog.{workspaceId,targetId?,targetType?,clusterId?}",
        "servers[].{id,name,url,type,enabled,isSystem,canDelete,canEditConnection,canToggle,authType,publicHeaders,connectionStatus,lastDiscoveryAt,lastDiscoveryError}",
        "servers[].toolCounts.{total,enabledConfigured,enabledEffective,writeConfigured,writeEffective}",
        "serverTools.items[].{name,description,capability,version,source,enabledConfigured,enabledEffective,effectiveDisabledReason}",
        "targetTools.{workspaceId,targetId,targetType,permissions.{canEdit,editableRoles?}}",
        "targetTools.items[].{id,label,description,enabled,capability,runtimeKind,visibility.{appearsInAssistantToolList,appearsInRunEnabledTools,appearsInToolCalls},config.domainFilters.{allowedDomains,blockedDomains}}",
        "targetSkills.items[].{id,name,description,enabled,validationStatus,validationErrors,bundleStats.{fileCount,totalBytes},source.{type,repoUrl?,ref?,subpath?,commitSha?,syncStatus},createdAt,updatedAt}",
        "targetSkillDetail.files[].{path,content,sizeBytes}"
      ],
      "requestFields": {
        "patchCluster": ["name?", "namespaceInclude?", "namespaceExclude?", "writeConfirmationRequiredOverride?"],
        "registerVirtualMachine": ["name", "hostname?", "osFamily?", "serviceManager?", "allowedLogSources?"],
        "patchVirtualMachine": ["name?", "hostname?", "allowedLogSources?"],
        "postMessage": ["content", "toolAccessMode", "clientMessageId"]
      },
      "responseFields": {
        "user": ["quota.workspaceMemberships.{used,limit}"],
        "workspace": ["plan.{key,name}", "currentUserRoleTemplate?", "permissions", "quota.members.{used,limit}", "quota.kubernetesClusters.{used,limit}", "quota.virtualMachines.{used,limit}"],
        "workspaceAiSettings": [
          "workspaceId",
          "defaultProvider",
          "defaultModel",
          "reasoningSummaryMode",
          "reasoningEffort",
          "allowedReasoningSummaryModes",
          "allowedReasoningEfforts",
          "reasoningSummariesEnabled",
          "allowedProviders",
          "allowedModels",
          "providers[].{provider,configured,enabled}",
          "no API key values, secret names, or reasoning summary text"
        ],
        "roleTemplate": ["key", "displayName", "description", "kind", "capabilities", "capabilityGroups[].{key,capabilities,sortOrder}", "protected", "sortOrder"],
        "membership": ["role", "roleTemplate?"],
        "invitation": ["role", "roleTemplate?"],
        "auditEvent": ["id", "workspaceId", "category", "eventType", "operation", "actor", "object", "summary", "metadata", "occurredAt"],
        "quotaExceeded": ["error.code=QUOTA_EXCEEDED", "error.details.{quotaKey,used,limit}"],
        "cluster": ["writeConfirmationPolicy"],
        "clusterRegistration": ["cluster", "agentKey"],
        "rotateAgentKey": ["clusterId", "agentKey", "keyVersion"],
        "virtualMachineRegistration": ["virtualMachine", "agentKey", "installInstructions"],
        "rotateVirtualMachineAgentKey": ["vmId", "agentKey", "keyVersion", "installInstructions"],
        "sessionList": ["items", "items[].targetId", "items[].targetType", "items[].clusterId?", "items[].createdBy", "items[].createdByUser.{id,displayName}?", "nextCursor?"],
        "targetChatActivity": ["targetId", "targetType", "targetName", "windowSeconds", "generatedAt", "recentActivity[].{sessionId,title,createdBy,createdByUser?,lastActivityAt,lastRunId?,lastRunStatus?,activeRun?,hasActiveRun,hasRecentWriteCapableRun,latestToolAccessMode?}"],
        "conversationOwnerRequired": ["error.code=CONVERSATION_OWNER_REQUIRED", "error.retryable=false"],
        "runDetails": ["targetId", "targetType", "clusterId?"],
        "runApprovals": ["[].targetId", "[].targetType", "[].clusterId?", "[].summary?"],
        "runApprovalDecision": ["targetId", "targetType", "clusterId?", "summary?", "conflict.approval.{targetId,targetType,clusterId?,summary?}"],
        "postMessageAccepted": ["message_id", "run_id"],
        "runEventFrame": ["schema_version", "run_id", "seq", "ts", "type", "payload"]
      }
    }
  }
}
